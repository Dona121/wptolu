# Plantilla de variables de entorno. Copia a .env y completa los valores.
#   cp .env.example .env
# El archivo .env real NO se versiona (contiene secretos).

# Genera una clave nueva para producción, p. ej.:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY="cambia-esto-por-una-clave-larga-y-aleatoria"

# 0/false en producción. Nunca dejes DEBUG activo en un sitio público.
DEBUG="False"

# Dominios permitidos, separados por coma (sin http://).
ALLOWED_HOSTS="viajesventasyturismotolu.com,www.viajesventasyturismotolu.com"

# Cadena de conexión a PostgreSQL. Si se omite, usa SQLite local.
# Supabase: usa el "Session pooler" (puerto 5432) para migraciones.
DATABASE_URL="postgresql://usuario:password@host:5432/postgres"
